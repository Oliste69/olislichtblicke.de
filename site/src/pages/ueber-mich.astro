---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getPhotos, urlFor } from '../lib/sanity'

const photos = await getPhotos()
const portrait = photos[0]
---

<BaseLayout title="Über mich" description="Über Oliver – Fotograf aus Essen, Leidenschaft für Tierfotografie und Licht.">

  <div style="padding-top:5rem;">
    <section class="section">
      <div class="section-inner">
        <div class="about-inner">

          <div class="about-img reveal">
            {portrait?.image
              ? <img src={urlFor(portrait.image).width(700).height(950).fit('crop').url()} alt="Oliver" loading="lazy" />
              : <div style="aspect-ratio:3/4;background:var(--stone);"></div>
            }
          </div>

          <div class="about-text reveal">
            <p class="section-label">Wer ich bin</p>
            <div class="divider"></div>
            <h1 class="section-title">
              Hallo, ich bin<br />
              <em style="font-style:italic;color:var(--sand);">Oliver.</em>
            </h1>
            <p class="about-body">
              Fotograf aus Essen mit einer Leidenschaft für Tierfotografie
              und die Schönheit des Lichts. Unter dem Namen <strong>Olis Lichtblicke</strong>
              halte ich Momente fest, die sonst im Alltag untergehen würden.
            </p>
            <p class="about-body">
              Jedes Bild ist für mich eine Einladung, innezuhalten und die
              Welt durch einen anderen Blickwinkel zu sehen – geduldig,
              aufmerksam und mit einem Gespür für den richtigen Moment.
            </p>
            <div class="about-stats">
              <div>
                <p class="stat-num">20+</p>
                <p class="stat-label">Jahre Erfahrung</p>
              </div>
              <div>
                <p class="stat-num">∞</p>
                <p class="stat-label">Leidenschaft</p>
              </div>
              <div>
                <p class="stat-num">RAW</p>
                <p class="stat-label">Immer</p>
              </div>
            </div>
            <div style="display:flex;gap:1rem;flex-wrap:wrap;">
              <a href="/portfolio" class="btn-primary">Portfolio ansehen</a>
              <a href="/kontakt" class="btn-outline">Kontakt aufnehmen</a>
            </div>
          </div>

        </div>
      </div>
    </section>
  </div>

  <!-- ── Ausrüstung ── -->
  <section class="section equip-section">
    <div class="section-inner">
      <div class="reveal">
        <p class="section-label">Was ich nutze</p>
        <h2 class="section-title">Meine Ausrüstung</h2>
      </div>
      <div class="equip-grid reveal">
        <div class="equip-card">
          <span class="equip-icon">⬡</span>
          <p class="equip-name">Sony Alpha 7 IV</p>
          <p class="equip-desc">Mein Hauptgehäuse – 33 MP Vollformat, hervorragende Dynamik und zuverlässig bei jedem Licht.</p>
        </div>
        <div class="equip-card">
          <span class="equip-icon">⬡</span>
          <p class="equip-name">Sigma 150–600 mm</p>
          <p class="equip-desc">Mein treuer Begleiter für Tierfotografie – enorme Reichweite für Wildtiere und Vögel.</p>
        </div>
        <div class="equip-card">
          <span class="equip-icon">⬡</span>
          <p class="equip-name">Tamron 17–28 mm</p>
          <p class="equip-desc">Vielseitig für Landschaft, Architektur und Reportage – kompakt und lichtstark.</p>
        </div>
        <div class="equip-card">
          <span class="equip-icon">⬡</span>
          <p class="equip-name">Sigma 70 mm Macro</p>
          <p class="equip-desc">Für Nahaufnahmen und Details – gestochen scharf und mit wunderschönem Bokeh.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Schwerpunkte ── -->
  <section class="section focus-section">
    <div class="section-inner">
      <div class="reveal">
        <p class="section-label">Was mich bewegt</p>
        <h2 class="section-title">Meine Schwerpunkte</h2>
      </div>
      <div class="focus-grid reveal">
        <div class="focus-item">
          <div class="focus-num">01</div>
          <h3 class="focus-title">Tierfotografie</h3>
          <p class="focus-body">Tiere in ihrer natürlichen Umgebung zu beobachten und den perfekten Moment einzufangen – das ist meine größte Leidenschaft.</p>
        </div>
        <div class="focus-item">
          <div class="focus-num">02</div>
          <h3 class="focus-title">Landschaft</h3>
          <p class="focus-body">Weite, Stille und das besondere Licht der goldenen Stunde – Landschaftsfotografie gibt mir Ruhe und Perspektive.</p>
        </div>
        <div class="focus-item">
          <div class="focus-num">03</div>
          <h3 class="focus-title">Architektur</h3>
          <p class="focus-body">Linien, Strukturen und Kontraste – ich sehe in Gebäuden und Räumen eine eigene Bildsprache.</p>
        </div>
        <div class="focus-item">
          <div class="focus-num">04</div>
          <h3 class="focus-title">Street</h3>
          <p class="focus-body">Das Leben auf der Straße, ungefiltert und ehrlich – spontane Momente die man nicht inszenieren kann.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ── Ausrüstung ── */
.equip-section { background: var(--stone); }
.equip-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
}
.equip-card {
  background: var(--cream);
  padding: 2rem 1.5rem;
  border-top: 2px solid var(--sand);
}
.equip-icon {
  display: block;
  font-size: 1.2rem;
  color: var(--sand);
  margin-bottom: 1rem;
}
.equip-name {
  font-family: var(--font-display);
  font-size: 1.25rem;
  font-weight: 400;
  color: var(--charcoal);
  margin-bottom: 0.75rem;
}
.equip-desc {
  font-size: 0.88rem;
  color: var(--muted);
  line-height: 1.7;
}

/* ── Schwerpunkte ── */
.focus-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 3rem 2rem;
}
.focus-num {
  font-family: var(--font-display);
  font-size: 3rem;
  font-weight: 300;
  color: var(--stone);
  line-height: 1;
  margin-bottom: 1rem;
}
.focus-title {
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-weight: 400;
  color: var(--charcoal);
  margin-bottom: 0.75rem;
}
.focus-body {
  font-size: 0.88rem;
  color: var(--muted);
  line-height: 1.75;
}

@media (max-width: 900px) {
  .equip-grid { grid-template-columns: repeat(2, 1fr); }
  .focus-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 550px) {
  .equip-grid { grid-template-columns: 1fr; }
  .focus-grid { grid-template-columns: 1fr; }
}
</style>
